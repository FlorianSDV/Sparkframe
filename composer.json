{
    "name": "floriansdv/sparkframe",
    "version": "dev-master",
    "description": "A simple framework to help you get started with creating personal projects",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sparkframe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sparkframe\\Tests\\": "tests/"
        }
    },
    "files": [
      "src/Functions/SessionFunctions.php",
      "src/Functions/ViewFunctions.php"
    ],
    "authors": [
        {
            "name": "FlorianSDV",
            "email": "93703843+FlorianSDV@users.noreply.github.com"
        }
    ],
    "require": {
      "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "friendsofphp/php-cs-fixer": "^3.92",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    }
}
